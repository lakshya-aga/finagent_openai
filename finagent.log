_ohlcv, name="prices_ohlcv (daily OHLCV)")'}, {'cell_type': 'markdown', 'id': '19163c80', 'metadata': {}, 'source': 'Task 2 — Construct approximate dollar bars from daily OHLCV (research_bars.build_dollar_bars_from_ohlcv)'}, {'cell_type': 'code', 'execution_count': None, 'id': '174af5ce', 'metadata': {}, 'outputs': [], 'source': '# Execute task: build_dollar_bars\n# Parameters: dollar_value_per_bar=\'median_20d\', min_obs_per_bar=1, debug=True\n\ndollar_bars = research_bars.build_dollar_bars_from_ohlcv(\n    ohlcv=prices_ohlcv,\n    dollar_value_per_bar="median_20d",\n    min_obs_per_bar=1,\n    debug=True,\n)\n\npeek(dollar_bars, name="dollar_bars (approx from daily OHLCV)")\nprint("Columns:", list(dollar_bars.columns))'}, {'cell_type': 'markdown', 'id': '230658a0', 'metadata': {}, 'source': 'Task 3 — Estimate daily volatility for thresholds/targets (mlfinlab.util.volatility.get_daily_vol)'}, {'cell_type': 'code', 'execution_count': None, 'id': '7a68e148', 'metadata': {}, 'outputs': [], 'source': '# Execute task: daily_vol\nclose_series = dollar_bars["Close"].dropna()\nvol_series = get_daily_vol(close=close_series, lookback=100)\n\npeek(vol_series.to_frame("vol"), name="vol_series (daily vol)")'}, {'cell_type': 'markdown', 'id': '03c7d5d7', 'metadata': {}, 'source': 'Task 4 — Detect events via symmetric CUSUM on dollar-bar closes (mlfinlab.filters.filters.cusum_filter)'}, {'cell_type': 'code', 'execution_count': None, 'id': 'c616f55b', 'metadata': {}, 'outputs': [], 'source': '# Execute task: cusum_events\n# Threshold set as vol_series * 1.0 per task spec\n# Align threshold index to price series\nthreshold = vol_series.reindex(close_series.index).fillna(method=\'ffill\') * 1.0\n\n# cusum_filter returns event timestamps\nt_events = cusum_filter(raw_time_series=close_series, threshold=threshold, time_stamps=True)\n\nprint(f"Detected {len(t_events)} events via CUSUM")\nprint("First 10 event timestamps:")\nprint(pd.DatetimeIndex(t_events)[:10])'}, {'cell_type': 'markdown', 'id': 'a6511f3e', 'metadata': {}, 'source': 'Task 5 — Apply triple barrier to get event spans and targets (mlfinlab.labeling.labeling.get_events)'}, {'cell_type': 'code', 'execution_count': None, 'id': '147f7233', 'metadata': {}, 'outputs': [], 'source': '# Execute task: triple_barrier_events\n# pt_sl = [1.0, 1.0]; min_ret = 0.001; vertical_barrier_times=False; side_prediction=None; verbose=True\n\npt_sl = [1.0, 1.0]\nmin_ret = 0.001\n\ntb_events = get_events(\n    close=close_series,\n    t_events=pd.DatetimeIndex(t_events),\n    pt_sl=pt_sl,\n    target=vol_series,\n    min_ret=min_ret,\n    num_threads=4,\n    vertical_barrier_times=False,\n    side_prediction=None,\n    verbose=True,\n)\n\npeek(tb_events, name="tb_events (triple barrier events)")'}, {'cell_type': 'markdown', 'id': '3dd544fe', 'metadata': {}, 'source': 'Task 6 — Create direction labels from triple-barrier events (mlfinlab.labeling.labeling.get_bins)'}, {'cell_type': 'code', 'execution_count': None, 'id': '5c85769d', 'metadata': {}, 'outputs': [], 'source': '# Execute task: make_labels\nlabels = get_bins(triple_barrier_events=tb_events, close=close_series)\n\n# Basic sanity: bin distribution\nlabel_counts = labels[\'bin\'].value_counts(dropna=False)\nprint("Label distribution (bin):")\nprint(label_counts)\n\npeek(labels, name="labels (first bins)")'}, {'cell_type': 'markdown', 'id': '8d2abf28', 'metadata': {}, 'source': 'Task 7 — Build compact feature set on dollar bars (research_ml.build_features_basic)'}, {'cell_type': 'code', 'execution_count': None, 'id': '3121d52b', 'metadata': {}, 'outputs': [], 'source': '# Execute task: build_features\nX, y, meta = research_ml.build_features_basic(\n    ohlcv=dollar_bars,\n    labels=labels,\n    feature_windows=[5, 10, 20],\n    include=["ret_lag1", "ret_lag5", "vol_ewm", "zscore_20", "rsi_14"],\n    drop_na=True,\n    debug=True,\n)\n\nprint("Features shape:", X.shape)\nprint("Target shape:", y.shape)\npeek(X, name="X (features)")\npeek(y.to_frame(\'y\'), name="y (labels aligned)")'}, {'cell_type': 'markdown', 'id': '0e9b818d', 'metadata': {}, 'source': 'Task 8 — Train baseline classifier and evaluate with time-based splits (research_ml.train_eval_time_split)'}, {'cell_type': 'code', 'execution_count': None, 'id': '22e89432', 'metadata': {}, 'outputs': [], 'source': '# Execute task: train_eval\ncv_metrics, pred_proba, pred_label = research_ml.train_eval_time_split(\n    X=X,\n    y=y,\n    index=X.index,\n    model_type="logistic_regression",\n    time_splits=5,\n    test_size_fraction=0.2,\n    standardize=True,\n    class_weight="balanced",\n    random_state=42,\n    debug=True,\n)\n\nprint("Cross-validated metrics (summary):")\nfor k, v in cv_metrics.items():\n    print(f"  {k}: {v}")\n\npeek(pred_label.to_frame(\'pred_label\'), name="Out-of-sample predicted labels")\npeek(pred_proba.to_frame(\'pred_proba\'), name="Out-of-sample predicted probas")'}, {'cell_type': 'markdown', 'id': '6ed17b83', 'metadata': {}, 'source': 'Task 9 — Convert predictions to SPY weights (directional, unit leverage) (portfolio.make_weights_from_predictions)'}, {'cell_type': 'code', 'execution_count': None, 'id': '8ef74cd1', 'metadata': {}, 'outputs': [], 'source': '# Execute task: portfolio_weights\nasset_weights = portfolio.make_weights_from_predictions(\n    pred_label=pred_label,\n    pred_proba=pred_proba,\n    long_short=True,\n    prob_threshold=0.5,\n    max_leverage=1.0,\n    align_to_index=dollar_bars.index,\n    debug=True,\n)\n\npeek(asset_weights, name="asset_weights (SPY)")'}, {'id': '63fd1a2a', 'cell_type': 'markdown', 'source': 'Task 10 — Compute portfolio returns using SPY close-to-close returns (portfolio.compute_returns_from_weights)', 'metadata': {}}], 'metadata': {'kernelspec': {'display_name': 'FinAgent Python', 'language': 'python', 'name': 'finagent-python'}, 'language_info': {'name': 'python', 'version': '3.13.11'}}, 'nbformat': 4, 'nbformat_minor': 5}, 'path': PosixPath('outputs/notebook_5.ipynb')}
