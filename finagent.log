ect\ndisplay(daily_vol.tail())\nprint("daily_vol.describe():\\n", daily_vol.describe())'}, {'cell_type': 'code', 'execution_count': 4, 'id': '1a1ff325', 'metadata': {}, 'outputs': [{'output_type': 'stream', 'name': 'stdout', 'text': "Detected 2509 events. Sample:\nDatetimeIndex(['2015-01-05', '2015-01-06', '2015-01-07', '2015-01-08',\n               '2015-01-09', '2015-01-12', '2015-01-13', '2015-01-14',\n               '2015-01-15', '2015-01-16'],\n              dtype='datetime64[ns]', freq=None)\n"}], 'source': '# 3) Event detection via symmetric CUSUM (mlfinlab.filters.filters.cusum_filter)\n# Use a threshold as a fraction of recent volatility; here, a fixed multiple of the median vol.\nthreshold = float(daily_vol.median() * 0.5)\n\nt_events = cusum_filter(raw_time_series=close, threshold=threshold, time_stamps=True)\nprint(f"Detected {len(t_events)} events. Sample:")\nprint(pd.DatetimeIndex(t_events)[:10])'}, {'cell_type': 'code', 'execution_count': 5, 'id': '683526ac', 'metadata': {}, 'outputs': [{'output_type': 'stream', 'name': 'stdout', 'text': 't1 (vertical barriers) sample:\nSeries([], dtype: object)\n'}], 'source': '# 4) Vertical barriers (mlfinlab.labeling.labeling.add_vertical_barrier)\n# Set a 5-day vertical barrier horizon\nvertical_horizon_days = 5\n\nt1 = add_vertical_barrier(\n    t_events=pd.Series(index=pd.DatetimeIndex(t_events), dtype=float),\n    close=close,\n    num_days=vertical_horizon_days,\n)\nprint("t1 (vertical barriers) sample:")\nprint(t1.dropna().head())'}, {'cell_type': 'code', 'execution_count': 6, 'id': '6acd5e8e', 'metadata': {}, 'outputs': [{'output_type': 'stream', 'name': 'stderr', 'text': "/var/folders/jr/prby656n267_0pztcwybgy5r0000gn/T/ipykernel_61960/2919996425.py:7: FutureWarning: Series.fillna with 'method' is deprecated and will raise in a future version. Use obj.ffill() or obj.bfill() instead.\n  target = daily_vol.reindex(close.index).fillna(method='ffill')\n"}, {'output_type': 'error', 'ename': 'TypeError', 'evalue'