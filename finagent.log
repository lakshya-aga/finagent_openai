Volume', 'DollarValue']\n"}], 'source': '# Execute task: build_dollar_bars\n# Parameters: dollar_value_per_bar=\'median_20d\', min_obs_per_bar=1, debug=True\n\ndollar_bars = build_dollar_bars_from_ohlcv(\n    ohlcv=prices_ohlcv,\n    dollar_value_per_bar="median_20d",\n    min_obs_per_bar=1,\n    debug=True,\n)\n\npeek(dollar_bars, name="dollar_bars (approx from daily OHLCV)")\nprint("Columns:", list(dollar_bars.columns))'}, {'cell_type': 'markdown', 'id': '230658a0', 'metadata': {}, 'source': 'Task 3 — Estimate daily volatility for thresholds/targets (mlfinlab.util.volatility.get_daily_vol)'}, {'cell_type': 'code', 'execution_count': 4, 'id': '7a68e148', 'metadata': {}, 'outputs': [{'output_type': 'stream', 'name': 'stdout', 'text': '\n>>> vol_series (daily vol): shape=(1731, 1) index_range=(2015-01-05 00:00:00 -> 2024-12-31 00:00:00)\n'}, {'output_type': 'display_data', 'metadata': {}, 'data': {'text/plain': '                 vol\nDateTime            \n2015-01-05       NaN\n2015-01-06  0.006540\n2015-01-08  0.031185\n2015-01-09  0.028728\n2015-01-13  0.025435', 'text/html': '<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border="1" class="dataframe">\n  <thead>\n    <tr style="text-align: right;">\n      <th></th>\n      <th>vol</th>\n    </tr>\n    <tr>\n      <th>DateTime</th>\n      <th></th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>2015-01-05</th>\n      <td>NaN</td>\n    </tr>\n    <tr>\n      <th>2015-01-06</th>\n      <td>0.006540</td>\n    </tr>\n    <tr>\n      <th>2015-01-08</th>\n      <td>0.031185</td>\n    </tr>\n    <tr>\n      <th>2015-01-09</th>\n      <td>0.028728</td>\n    </tr>\n    <tr>\n      <th>2015-01-13</th>\n      <td>0.025435</td>\n    </tr>\n  </tbody>\n</table>\n</div>'}}], 'source': '# Execute task: daily_vol\nclose