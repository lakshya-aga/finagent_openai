=prices_ohlcv,\n    dollar_value_per_bar="median_20d",\n    min_obs_per_bar=1,\n    debug=True,\n)\n\npeek(dollar_bars, name="dollar_bars (approx from daily OHLCV)")\nprint("Columns:", list(dollar_bars.columns))'}, {'cell_type': 'markdown', 'id': '230658a0', 'metadata': {}, 'source': 'Task 3 — Estimate daily volatility for thresholds/targets (mlfinlab.util.volatility.get_daily_vol)'}, {'cell_type': 'code', 'execution_count': 4, 'id': '7a68e148', 'metadata': {}, 'outputs': [{'name': 'stdout', 'output_type': 'stream', 'text': '\n>>> vol_series (daily vol): shape=(1731, 1) index_range=(2015-01-05 00:00:00 -> 2024-12-31 00:00:00)\n'}, {'data': {'text/html': '<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border="1" class="dataframe">\n  <thead>\n    <tr style="text-align: right;">\n      <th></th>\n      <th>vol</th>\n    </tr>\n    <tr>\n      <th>DateTime</th>\n      <th></th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>2015-01-05</th>\n      <td>NaN</td>\n    </tr>\n    <tr>\n      <th>2015-01-06</th>\n      <td>0.006540</td>\n    </tr>\n    <tr>\n      <th>2015-01-08</th>\n      <td>0.031185</td>\n    </tr>\n    <tr>\n      <th>2015-01-09</th>\n      <td>0.028728</td>\n    </tr>\n    <tr>\n      <th>2015-01-13</th>\n      <td>0.025435</td>\n    </tr>\n  </tbody>\n</table>\n</div>', 'text/plain': '                 vol\nDateTime            \n2015-01-05       NaN\n2015-01-06  0.006540\n2015-01-08  0.031185\n2015-01-09  0.028728\n2015-01-13  0.025435'}, 'metadata': {}, 'output_type': 'display_data'}], 'source': '# Execute task: daily_vol\nclose_series = dollar_bars["Close"].dropna()\nvol_series = get_daily_vol(close=close_series, lookback=100)\n\npeek(vol_series.to_frame("vol"), name="vol_series (daily vol)")'}, {'cell_type': 'markdown', 'id': '03c7d5d7', 'metadata': {}, 'source': 'Task 4 — Detect events via symmetric CUSUM on dollar-bar closes (mlfinlab.filters.filters.cusum_filter)'}, {'cell_type': 'code', 'execution_count': 5, 'id': 'c616f55b', 'metadata': {}, 'outputs': [{'name': 'stdout', 'output_type': 'stream', 'text': "Detected 1718 events via CUSUM\nFirst 10 event timestamps:\nDatetimeIndex(['2015-01-06', '2015-01-08', '2015-01-09', '2015-01-13', '2015-01-14', '2015-01-15', '2015-01-16', '2015-01-21', '2015-01-22', '2015-01-26'], dtype='datetime64[ns]', freq=None)\n"}, {'name': 'stderr', 'output_type': 'stream', 'text': "/var/folders/jr/prby656n267_0pztcwybgy5r0000gn/T/ipykernel_86410/1866813802.py:4: FutureWarning: Series.fillna with 'method' is deprecated and will raise in a future version. Use obj.ffill() or obj.bfill() instead.\n  threshold = vol_series.reindex(close_series.index).fillna(method='ffill') * 1.0\n"}], 'source': '# Execute task: cusum_events\n# Threshold set as vol_series * 1.0 per task spec\n# Align threshold index to price series\nthreshold = vol_series.reindex(close_series.index).fillna(method=\'ffill\') * 1.0\n\n# cusum_filter returns event timestamps\nt_events = cusum_filter(raw_time_series=close_series, threshold=threshold, time_stamps=True)\n\nprint(f"Detected {len(t_events)} events via CUSUM")\nprint("First 10 event timestamps:")\nprint(pd.DatetimeIndex(t_events)[:10])'}, {'cell_type': 'markdown', 'id': 'a6511f3e', 'metadata': {}, 'source': 'Task 5 — Apply triple barrier to get event spans and targets (mlfinlab.labeling.labeling.get_events)'}, {'cell_type': 'code', 'execution_count': 6, 'id': '147f7233', 'metadata': {}, 'outputs': [{'name': 'stderr', 'output_type': 'stream', 'text': '1/4 apply_pt_sl_on_t1 done after 0.02 minutes. 0.06 minutes remaining.\n2/4 apply_pt_sl_on_t1 done after 0.02 minutes. 0.02 minutes remaining.\n3/4 apply_pt_sl_on_t1 done after 0.02 minutes. 0.01 minutes remaining.\n4/4 apply_pt_sl_on_t1 done after 0.02 minutes. done.\n'}, {'name': 'stdout', 'output_type': 'stream', 'text': '\n>>> tb_events (triple barrier events): shape=(1718, 4) index_range=(2015-01-06 00:00:00 -> 2024-12-31 00:00:00)\n'}, {'data': {'text/html': '<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border="1" class="dataframe">\n  <thead>\n    <tr style="text-align: right;">\n      <th></th>\n      <th>t1</th>\n      <th>trgt</th>\n      <th>pt</th>\n      <th>sl</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>2015-01-06</th>\n      <td>2015-01-08</td>\n      <td>0.006540</td>\n      <td>1.0</td>\n      <td>1.0</td>\n    </tr>\n    <tr>\n      <th>2015-01-08</th>\n      <td>2015-01-15</td>\n      <td>0.031185</td>\n      <td>1.0</td>\n      <td>1.0</td>\n    </tr>\n    <tr>\n      <th>2015-01-09</th>\n      <td>2015-02-18</td>\n      <td>0.028728</td>\n      <td>1.0</td>\n      <td>1.0</td>\n    </tr>\n    <tr>\n      <th>2015-01-13</th>\n      <td>2015-02-13</td>\n      <td>0.025435</td>\n      <td>1.0</td>\n      <td>1.0</td>\n    </tr>\n    <tr>\n      <th>2015-01-14</th>\n      <td>2015-01-22</td>\n      <td>0.023615</td>\n      <td>1.0</td>\n      <td>1.0</td>\n    </tr>\n  </tbody>\n</table>\n</div>', 'text/plain': '                   t1      trgt   pt   sl\n2015-01-06 2015-01-08  0.006540  1.0  1.0\n2015-01-08 2015-01-15  0.031185  1.0  1.0\n2015-01-09 2015-02-18  0.028728  1.0  1.0\n2015-01-13 2015-02-13  0.025435  1.0  1.0\n2015-01-14 2015-01-22  0.023615  1.0  1.0'}, 'metadata': {}, 'output_type': 'display_data'}], 'source': '# Execute task: triple_barrier_events\n# pt_sl = [1.0, 1.0]; min_ret = 0.001; vertical_barrier_times=False; side_prediction=None; verbose=True\n\npt_sl = [1.0, 1.0]\nmin_ret = 0.001\n\ntb_events = get_events(\n    close=close_series,\n    t_events=pd.DatetimeIndex(t_events),\n    pt_sl=pt_sl,\n    target=vol_series,\n    min_ret=min_ret,\n    num_threads=4,\n    vertical_barrier_times=False,\n    side_prediction=None,\n    verbose=True,\n)\n\npeek(tb_events, name="tb_events (triple barrier events)")'}, {'cell_type': 'markdown', 'id': '3dd544fe', 'metadata': {}, 'source': 'Task 6 — Create direction labels from triple-barrier events (mlfinlab.labeling.labeling.get_bins)'}, {'cell_type': 'code', 'execution_count': 7, 'id': '5c85769d', 'metadata': {}, 'outputs': [{'name': 'stdout', 'output_type': 'stream', 'text': 'Label distribution (bin):\nbin\n 1.0    1022\n-1.0     694\nName: count, dtype: int64\n\n>>> labels (first bins): shape=(1716, 2) index_range=(2015-01-06 00:00:00 -> 2024-12-27 00:00:00)\n'}, {'data': {'text/html': '<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border="1" class="dataframe">\n  <thead>\n    <tr style="text-align: right;">\n      <th></th>\n      <th>ret</th>\n      <th>bin</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>2015-01-06</th>\n      <td>0.030428</td>\n      <td>1.0</td>\n    </tr>\n    <tr>\n      <th>2015-01-08</th>\n      <td>-0.033415</td>\n      <td>-1.0</td>\n    </tr>\n    <tr>\n      <th>2015-01-09</th>\n      <td>0.028788</td>\n      <td>1.0</td>\n    </tr>\n    <tr>\n      <th>2015-01-13</th>\n      <td>0.038104</td>\n      <td>1.0</td>\n    </tr>\n    <tr>\n      <th>2015-01-14</th>\n      <td>0.026088</td>\n      <td>1.0</td>\n    </tr>\n  </tbody>\n</table>\n</div>', 'text/plain': '                 ret  bin\n2015-01-06  0.030428  1.0\n2015-01-08 -0.033415 -1.0\n2015-01-09  0.028788  1.0\n2015-01-13  0.038104  1.0\n2015-01-14  0.026088  1.0'}, 'metadata': {}, 'output_type': 'display_data'}], 'source': '# Execute task: make_labels\nlabels = get_bins(triple_barrier_events=tb_events, close=close_series)\n\n# Basic sanity: bin distribution\nlabel_counts = labels[\'bin\'].value_counts(dropna=False)\nprint("Label distribution (bin):")\nprint(label_counts)\n\npeek(labels, name="labels (first bins)")'}, {'cell_type': 'markdown', 'id': '8d2abf28', 'metadata': {}, 'source': 'Task 7 — Build compact feature set on dollar bars (research_ml.build_features_basic)'}, {'cell_type': 'code', 'execution_count': None, 'id': '0645fb6c', 'metadata': {}, 'outputs': [], 'source': '# Execute task: build_features\nX, y, meta = build_features_basic(\n    ohlcv=dollar_bars,\n    labels=labels,\n    feature_windows=[5, 10, 20],\n    include=["ret_lag1", "ret_lag5", "vol_ewm", "zscore_20", "rsi_14"],\n    drop_na=True,\n    debug=True,\n)\n\nprint("Features shape:", X.shape)\nprint("Target shape:", y.shape)\npeek(X, name="X (features)")\npeek(y.to_frame(\'y\'), name="y (labels aligned)")'}, {'cell_type': 'markdown', 'id': '0e9b818d', 'metadata': {}, 'source': 'Task 8 — Train baseline classifier and evaluate with time-based splits (research_ml.train_eval_time_split)'}, {'id': '27881a84', 'cell_type': 'code', 'metadata': {}, 'execution_count': None, 'source': '# Execute task: train_eval\ncv_metrics, pred_proba, pred_label = train_eval_time_split(\n    X=X,\n    y=y,\n    index=X.index,\n    model_type="logistic_regression",\n    time_splits=5,\n    test_size_fraction=0.2,\n    standardize=True,\n    class_weight="balanced",\n    random_state=42,\n    debug=True,\n)\n\nprint("Cross-validated metrics (summary):")\nfor k, v in cv_metrics.items():\n    print(f"  {k}: {v}")\n\npeek(pred_label.to_frame(\'pred_label\'), name="Out-of-sample predicted labels")\npeek(pred_proba.to_frame(\'pred_proba\'), name="Out-of-sample predicted probas")', 'outputs': []}, {'cell_type': 'markdown', 'id': '6ed17b83', 'metadata': {}, 'source': 'Task 9 — Convert predictions to SPY weights (directional, unit leverage) (portfolio.make_weights_from_predictions)'}, {'cell_type': 'code', 'execution_count': None, 'id': '8ef74cd1', 'metadata': {}, 'outputs': [], 'source': '# Execute task: portfolio_weights\nasset_weights = portfolio.make_weights_from_predictions(\n    pred_label=pred_label,\n    pred_proba=pred_proba,\n    long_short=True,\n    prob_threshold=0.5,\n    max_leverage=1.0,\n    align_to_index=dollar_bars.index,\n    debug=True,\n)\n\npeek(asset_weights, name="asset_weights (SPY)")'}, {'cell_type': 'markdown', 'id': '63fd1a2a', 'metadata': {}, 'source': 'Task 10 — Compute portfolio returns using SPY close-to-close returns (portfolio.compute_returns_from_weights)'}, {'cell_type': 'code', 'execution_count': None, 'id': 'faea3ec4', 'metadata': {}, 'outputs': [], 'source': '# Execute task: portfolio_returns\nasset_returns = portfolio.compute_returns_from_weights(\n    weights=asset_weights,\n    prices_close=close_series,\n    shift_weights_by_1=True,\n    gross_leverage_cap=1.0,\n    debug=True,\n)\n\npeek(asset_returns, name="asset_returns (SPY)")'}, {'cell_type': 'markdown', 'id': '55cbaf52', 'metadata': {}, 'source': 'Final — Run user-defined backtest exactly once (consumes asset_weights and asset_returns)'}, {'cell_type': 'code', 'execution_count': None, 'id': '2cb258c6', 'metadata': {}, 'outputs': [], 'source': '# The environment is expected to provide `user_backtest(asset_weights: pd.DataFrame, asset_returns: pd.DataFrame)`\n# This call is required exactly once per the task specification.\ntry:\n    backtest_result = user_backtest(asset_weights=asset_weights, asset_returns=asset_returns)\n    print("Backtest finished. Summary:")\n    print(backtest_result)\nexcept NameError:\n    print("user_backtest function is not defined in the environment. Please define it and re-run this cell.")'}], 'metadata': {'kernelspec': {'display_name': 'FinAgent Python', 'language': 'python', 'name': 'finagent-python'}, 'language_info': {'name': 'python', 'version': '3.13.11'}}, 'nbformat': 4, 'nbformat_minor': 5}, 'path': PosixPath('outputs/notebook_5.ipynb')}
