mns:", list(dollar_bars.columns))'}, {'cell_type': 'markdown', 'id': '230658a0', 'metadata': {}, 'source': 'Task 3 — Estimate daily volatility for thresholds/targets (mlfinlab.util.volatility.get_daily_vol)'}, {'cell_type': 'code', 'execution_count': 4, 'id': '7a68e148', 'metadata': {}, 'outputs': [{'output_type': 'stream', 'name': 'stdout', 'text': '\n>>> vol_series (daily vol): shape=(1731, 1) index_range=(2015-01-05 00:00:00 -> 2024-12-31 00:00:00)\n'}, {'output_type': 'display_data', 'metadata': {}, 'data': {'text/plain': '                 vol\nDateTime            \n2015-01-05       NaN\n2015-01-06  0.006540\n2015-01-08  0.031184\n2015-01-09  0.028728\n2015-01-13  0.025434', 'text/html': '<div>\n<style scoped>\n    .dataframe tbody tr th:only-of-type {\n        vertical-align: middle;\n    }\n\n    .dataframe tbody tr th {\n        vertical-align: top;\n    }\n\n    .dataframe thead th {\n        text-align: right;\n    }\n</style>\n<table border="1" class="dataframe">\n  <thead>\n    <tr style="text-align: right;">\n      <th></th>\n      <th>vol</th>\n    </tr>\n    <tr>\n      <th>DateTime</th>\n      <th></th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <th>2015-01-05</th>\n      <td>NaN</td>\n    </tr>\n    <tr>\n      <th>2015-01-06</th>\n      <td>0.006540</td>\n    </tr>\n    <tr>\n      <th>2015-01-08</th>\n      <td>0.031184</td>\n    </tr>\n    <tr>\n      <th>2015-01-09</th>\n      <td>0.028728</td>\n    </tr>\n    <tr>\n      <th>2015-01-13</th>\n      <td>0.025434</td>\n    </tr>\n  </tbody>\n</table>\n</div>'}}], 'source': '# Execute task: daily_vol\nclose_series = dollar_bars["Close"].dropna()\nvol_series = get_daily_vol(close=close_series, lookback=100)\n\npeek(vol_series.to_frame("vol"), name="vol_series (daily vol)")'}, {'cell_type': 'markdown', 'id': '03c7d5d7', 'metadata': {}, 'source': 'Task 4 — Detect events via symmetric CUSUM on dollar-bar closes (mlfinlab.filters.filters.cusum_filter)'}, {'cell_type': 'code', 'execution_count': 5, 'id': 'c616f55b', 'metadata': {}, 'outputs': [{'output_type': 'stream', 'name': 'stdout', 'text': "Detected 1718 events via CUSUM\nFirst 10 event timestamps:\nDatetimeIndex(['2015-01-06', '2015-01-08', '2015-01-09', '2015-01-13', '2015-01-14', '2015-01-15', '2015-01-16', '2015-01-21', '2015-01-22', '2015-01-26'], dtype='datetime64[ns]', freq=None)\n"}, {'output_type': 'stream', 'name': 'stderr', 'text': "/var/folders/jr/prby656n267_0pztcwybgy5r0000gn/T/ipykernel_87812/1866813802.py:4: FutureWarning: Series.fillna with 'method' is deprecated and will raise in a future version. Use obj.ffill() or obj.bfill() instead.\n  threshold = vol_series.reindex(close_series.index).fillna(method='ffill') * 1.0\n"}], 'source': '# Execute task: cusum_events\n# Threshold set as vol_series * 1.0 per task spec\n# Align threshold index to price series\nthreshold = vol_series.reindex(close_series.index).fillna(method=\'ffill\') * 1.0\n\n# cusum_filter returns event timestamps\nt_events = cusum_filter(raw_time_series=close_series, threshold=threshold, time_stamps=True)\n\nprint(f"Detected {len(t_events)} events via CUSUM")\nprint("First 10 event timestamps:")\nprint(pd.DatetimeIndex(t_events)[:10])'}, {'cell_type': 'markdown', 'id': 'a6511f3e', 'metadata': {}, 'source': 'Task 5 — Apply triple barrier to get event spans and targets (mlfinlab.labeling.labeling.get_events)'}, {'cell_type': 'code', 'execution_count': 6, 'id': '147f7233', 'metadata': {}, 'outputs': [{'output_type': 'stream', 'name': 'stderr', 'text': '1/4 apply_pt_sl_on_t1 done after 0.03 minutes. 0.08 minutes remaining.\n2/4 apply_pt_sl_on_t1 done after 0.03 minutes. 0.03 minutes remaining.\n3/4 apply_pt_sl_on_t1 done after 0.03 minutes. 0.01 minutes remaining.\n4/4 apply_pt_sl_on_t1 done after 0.03 minutes. done.\n'}, {'output_type': 'stream', 'name': 'stdout', 'text': '\n>>> tb_events (triple barrier events): shape=(1718, 4) index_range=(2015-01-06 00:00:00 -> 2024-12-31 00:00:00)\n'}, {'output_type': 'display_data', 'me