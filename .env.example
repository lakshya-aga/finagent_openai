# ── Required: OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# Model overrides (optional — defaults are set in finagent/llm.py)
# OPENAI_MODEL=gpt-4o
# INTENT_CLASSIFIER_MODEL=gpt-4o-mini
# INTENT_CLASSIFIER_PROVIDER=openai

# ── MCP Server URLs ────────────────────────────────────────────────────
# Standalone dev usually runs data-mcp on 8001 to avoid colliding with
# finagent's default port 8000. Synapse's docker-compose overrides these
# with in-network service URLs.
FRUIT_THROWER_URL=http://localhost:8090/mcp/
DATA_MCP_URL=http://localhost:8001/sse

# ── OpenAI Vector Store (file search / knowledge base) ──────────────────
# OPENAI_VECTOR_STORE_ID=vs_your_store_id

# ── Rate Limiting ──────────────────────────────────────────────────────
# Max requests per minute per client on expensive endpoints.
# Set to 0 to disable rate limiting.
RATE_LIMIT_RPM=10

# ── Session Persistence ────────────────────────────────────────────────
# SQLite DB path for session storage. Default: outputs/sessions.db
# SESSION_DB_PATH=outputs/sessions.db
# Days before stale sessions are auto-cleaned. Default: 7
# SESSION_TTL_DAYS=7

# ── Experiment Store ───────────────────────────────────────────────────
# Path to the SQLite experiments database.
# FINAGENT_EXPERIMENT_DB=outputs/experiments.db

# ── Debate Configuration ──────────────────────────────────────────────
# Set to '1' to use the legacy bull/bear/moderator debate flow.
# DEBATE_LEGACY=0

# ── Trading Panel (LangGraph multi-agent debate) ───────────────────────
# Default LLM for panel agents. Supports openai, anthropic, ollama, google.
# PANEL_DEFAULT_MODEL=qwen3:4b
# OLLAMA_BASE_URL=http://localhost:11434
# ANTHROPIC_API_KEY=sk-ant-your-key
# GOOGLE_API_KEY=your-google-key

# ── Phoenix Tracing (LLM observability) ────────────────────────────────
# Set to enable OpenTelemetry-based tracing. No-op if unset.
# PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:4317
# PHOENIX_PROJECT_NAME=synapse

# ── Lineage ─────────────────────────────────────────────────────────────
# Timeout for runtime lineage extraction (seconds). Default: 180
# FINAGENT_LINEAGE_TIMEOUT=180
